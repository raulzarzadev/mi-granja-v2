---
// Only renders when PUBLIC_POSTHOG_KEY is set. The script below is a module;
// Vite statically inlines import.meta.env.PUBLIC_* at build time.
const hasKey = !!import.meta.env.PUBLIC_POSTHOG_KEY
---

{
  hasKey && (
    <script>
      import posthog from 'posthog-js'

      const key = import.meta.env.PUBLIC_POSTHOG_KEY
      const host = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com'

      posthog.init(key, {
        api_host: host,
        person_profiles: 'identified_only',
        defaults: '2025-05-24',
      })
    </script>
  )
}
