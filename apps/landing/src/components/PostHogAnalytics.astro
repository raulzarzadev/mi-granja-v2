---
// Only renders when PUBLIC_POSTHOG_KEY is set. The script below is a module;
// Vite statically inlines import.meta.env.PUBLIC_* at build time.
const hasKey = !!import.meta.env.PUBLIC_POSTHOG_KEY
const appVersion = import.meta.env.PUBLIC_APP_VERSION || '0.0.0'
---

{
  hasKey && (
    <script define:vars={{ appVersion }}>
      import posthog from 'posthog-js'
      import {
        APP_DOMAIN,
        ANALYTICS_EVENTS,
        POSTHOG_DEFAULT_OPTIONS,
        PH_DID_PARAM,
        appendDistinctIdToUrl,
      } from '@mi-granja/shared'

      const key = import.meta.env.PUBLIC_POSTHOG_KEY
      const host = import.meta.env.PUBLIC_POSTHOG_HOST || POSTHOG_DEFAULT_OPTIONS.api_host

      posthog.init(key, {
        ...POSTHOG_DEFAULT_OPTIONS,
        api_host: host,
      })
      posthog.register({
        app_domain: APP_DOMAIN.LANDING,
        app_version: appVersion,
      })

      // page_viewed (manual — capture_pageview is off in shared defaults).
      posthog.capture(ANALYTICS_EVENTS.page_viewed, {
        page_name: window.location.pathname,
      })

      // Cross-domain bridge: any anchor pointing at panel/dashboard gets
      // ?ph_did=<distinct_id> appended at click time. Click-time rewrite
      // (vs upfront DOM sweep) covers anchors added later by view
      // transitions or dynamic content. Cookies on .migranja.app handle
      // the same-root case; this URL param is the fallback for ITP /
      // Vercel preview hosts where the shared cookie can't be set.
      function isCrossDomainPanelLink(href) {
        return (
          href.startsWith('https://panel.migranja.app') ||
          href.startsWith('https://dashboard.migranja.app')
        )
      }

      // Read all data-ph-* attributes (except the event name) as event properties.
      function readProps(el) {
        const props = {}
        for (const { name, value } of Array.from(el.attributes)) {
          if (name.startsWith('data-ph-') && name !== 'data-ph-event') {
            props[name.slice('data-ph-'.length).replace(/-/g, '_')] = value
          }
        }
        return props
      }

      // Map well-known data-ph-event values to the canonical event names.
      // Existing CTAs use 'cta_click' — alias to 'cta_clicked'.
      const EVENT_ALIAS = {
        cta_click: ANALYTICS_EVENTS.cta_clicked,
      }

      // Delegated click tracking — any element with [data-ph-event] fires a capture.
      // Also rewrites outbound panel links with ?ph_did at click time.
      document.addEventListener(
        'click',
        (e) => {
          const eventTarget = e.target instanceof Element ? e.target : null
          // Outbound link rewrite — any anchor regardless of data-ph-event.
          const anchor = eventTarget?.closest('a[href]')
          if (anchor) {
            const href = anchor.getAttribute('href')
            const did = posthog.get_distinct_id()
            if (href && did && isCrossDomainPanelLink(href)) {
              anchor.setAttribute('href', appendDistinctIdToUrl(href, did))
            }
          }

          const target = eventTarget?.closest('[data-ph-event]')
          if (!target) return
          const raw = target.getAttribute('data-ph-event')
          if (!raw) return
          const eventName = EVENT_ALIAS[raw] || raw
          const props = readProps(target)
          if (eventName === ANALYTICS_EVENTS.cta_clicked) {
            props.cta_text = props.label || target.textContent?.trim() || ''
            props.cta_location = props.location || ''
          }
          posthog.capture(eventName, props)

          // Auto-derive funnel events from CTAs that link to /auth.
          // Skip if the markup already declared signup_started/login_clicked
          // explicitly (avoid double-fire).
          const href = target.getAttribute && target.getAttribute('href')
          if (href && /panel\.migranja\.app\/auth/.test(href)) {
            const location = props.location || props.cta_location || ''
            const isLoginCta = /login/i.test(location) || /sesi[oó]n/i.test(props.label || '')
            const derivedEvent = isLoginCta
              ? ANALYTICS_EVENTS.login_clicked
              : ANALYTICS_EVENTS.signup_started
            if (eventName !== derivedEvent) {
              posthog.capture(derivedEvent, { source_location: location })
            }
          }
        },
        { capture: true },
      )

      // FAQ: track when a <details data-ph-event="faq_opened"> is opened (not closed).
      document.querySelectorAll('details[data-ph-event]').forEach((el) => {
        el.addEventListener('toggle', () => {
          if (el.open) {
            const eventName = el.getAttribute('data-ph-event') || 'faq_opened'
            posthog.capture(eventName, readProps(el))
          }
        })
      })

      // pricing_viewed — fire once when the #pricing section enters the viewport.
      const pricingEl = document.getElementById('precios') || document.getElementById('pricing')
      if (pricingEl && 'IntersectionObserver' in window) {
        let pricingFired = false
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting && !pricingFired) {
                pricingFired = true
                posthog.capture(ANALYTICS_EVENTS.pricing_viewed)
                io.disconnect()
              }
            }
          },
          { threshold: 0.3 },
        )
        io.observe(pricingEl)
      }

      // Scroll depth milestones — fire each threshold once per page load.
      const thresholds = [25, 50, 75, 100]
      const fired = new Set()
      function checkScrollDepth() {
        const scrollTop = window.scrollY
        const docHeight = document.documentElement.scrollHeight - window.innerHeight
        if (docHeight <= 0) return
        const pct = Math.min(100, Math.round((scrollTop / docHeight) * 100))
        for (const t of thresholds) {
          if (pct >= t && !fired.has(t)) {
            fired.add(t)
            posthog.capture('scroll_depth', { percentage: t })
          }
        }
      }
      let scrollTicking = false
      window.addEventListener(
        'scroll',
        () => {
          if (scrollTicking) return
          scrollTicking = true
          requestAnimationFrame(() => {
            checkScrollDepth()
            scrollTicking = false
          })
        },
        { passive: true },
      )
      checkScrollDepth()
    </script>
  )
}
