---
const currentYear = new Date().getFullYear()
---

<footer class="bg-gray-900 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-8 sm:flex-row sm:justify-between">
      <div class="flex items-center gap-2">
        <img src="/logo/logo-migranja-blanco.svg" alt="Mi Granja" class="h-9" />
      </div>

      <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm" aria-label="Navegación del pie de página">
        <a
          href="#funcionalidades"
          class="text-gray-400 hover:text-white transition-colors"
          data-ph-event="nav_click"
          data-ph-location="footer"
          data-ph-destination="#funcionalidades"
          data-ph-label="Funcionalidades"
        >Funcionalidades</a>
        <a
          href="#especies"
          class="text-gray-400 hover:text-white transition-colors"
          data-ph-event="nav_click"
          data-ph-location="footer"
          data-ph-destination="#especies"
          data-ph-label="Especies"
        >Especies</a>
        <a
          href="#beneficios"
          class="text-gray-400 hover:text-white transition-colors"
          data-ph-event="nav_click"
          data-ph-location="footer"
          data-ph-destination="#beneficios"
          data-ph-label="Beneficios"
        >Beneficios</a>
        <a
          href="#faq"
          class="text-gray-400 hover:text-white transition-colors"
          data-ph-event="nav_click"
          data-ph-location="footer"
          data-ph-destination="#faq"
          data-ph-label="FAQ"
        >FAQ</a>
        <a
          href="https://panel.migranja.app/auth"
          class="text-gray-400 hover:text-white transition-colors"
          data-ph-event="cta_click"
          data-ph-location="footer_dashboard"
          data-ph-label="Dashboard"
        >Dashboard</a>
        <a
          href="mailto:hola@migranja.app"
          class="text-gray-400 hover:text-white transition-colors"
          data-ph-event="contact_click"
          data-ph-location="footer"
          data-ph-method="email"
        >hola@migranja.app</a>
      </nav>
    </div>

    <div class="mt-8 border-t border-gray-800 pt-8 text-center">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Mi Granja. Software de gestión ganadera gratuito.
      </p>
    </div>
  </div>
</footer>
