---
interface Props {
  title: string
  description: string
  canonicalURL?: string
}

const SITE_URL = 'https://www.migranja.app'

const { title, description, canonicalURL } = Astro.props
// Force canonical host to www.migranja.app regardless of how the page was reached
const canonical = canonicalURL || new URL(Astro.url.pathname, SITE_URL).href
const siteName = 'Mi Granja'
const ogImage = `${SITE_URL}/og-image.png`

const jsonLdSoftware = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Mi Granja',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description:
    'Software de gestión ganadera para controlar animales, reproducción, salud y colaboradores.',
  url: SITE_URL,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'MXN',
  },
  featureList: [
    'Registro de animales',
    'Control de reproducción',
    'Historial de salud',
    'Gestión de colaboradores',
    'Recordatorios automáticos',
    'Respaldo de datos',
  ],
  inLanguage: 'es',
}

const jsonLdOrg = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Mi Granja',
  url: SITE_URL,
  logo: `${SITE_URL}/logo/logo-migranja-verde.png`,
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mi Granja" />
    <meta name="theme-color" content="#16a34a" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mi Granja — Software ganadero en español" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Mi Granja — Software ganadero en español" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdSoftware)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrg)} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://panel.migranja.app" />
  </head>
  <body class="bg-white text-gray-900">
    <slot />

    <!-- Vercel Analytics + Speed Insights (bundled by Astro) -->
    <script>
      import { inject } from '@vercel/analytics'
      import { injectSpeedInsights } from '@vercel/speed-insights'
      inject()
      injectSpeedInsights()
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
