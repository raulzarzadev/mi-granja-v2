---
import { WHATSAPP_COMMUNITY_URL } from '@mi-granja/shared'
const WHATSAPP_URL = WHATSAPP_COMMUNITY_URL
---

<section id="comunidad" class="py-20 sm:py-24 bg-gradient-to-br from-green-50 via-white to-emerald-50">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-gray-200">
      <div class="absolute -top-16 -right-16 h-64 w-64 rounded-full bg-[#25D366]/10 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-emerald-400/10 blur-3xl"></div>

      <div class="relative grid gap-10 p-8 sm:p-12 lg:grid-cols-[1fr_auto] lg:items-center">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-[#25D366]/15 px-3 py-1 text-xs font-semibold text-[#1da851]">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.967-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
            </svg>
            Canal de WhatsApp · Gratis
          </span>

          <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Únete a la comunidad de Mi&nbsp;Granja
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Recibe soporte directo, reporta problemas y propón nuevas funcionalidades.
            Conéctate con otros ganaderos y mantente al tanto de las novedades.
          </p>

          <ul class="mt-6 grid gap-3 text-sm text-gray-700 sm:grid-cols-2">
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-[#25D366]">✓</span>
              Soporte rápido del equipo
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-[#25D366]">✓</span>
              Reporta bugs y problemas
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-[#25D366]">✓</span>
              Propón nuevas funcionalidades
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-[#25D366]">✓</span>
              Avisos de actualizaciones
            </li>
          </ul>
        </div>

        <div class="flex flex-col items-stretch gap-3 lg:items-end">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-[#25D366] px-6 py-4 text-base font-bold text-white shadow-lg hover:bg-[#1da851] transition-colors"
            data-ph-event="cta_click"
            data-ph-location="community_section"
            data-ph-label="Unirme al canal WhatsApp"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.967-.94 1.164-.173.198-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
            </svg>
            Unirme al canal
          </a>
          <p class="text-center text-xs text-gray-500 lg:text-right">Gratis · Sin spam · Cancela cuando quieras</p>
        </div>
      </div>
    </div>
  </div>
</section>
