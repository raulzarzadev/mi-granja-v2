---

---

<section id="precios" class="py-20 sm:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Planes simples y transparentes
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Empieza gratis con todas las funcionalidades. Paga solo cuando necesites crecer.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-4xl gap-8 lg:grid-cols-2">
      <!-- Plan Gratis -->
      <div class="flex flex-col rounded-2xl border-2 border-gray-200 bg-white p-8 shadow-sm">
        <div class="mb-6">
          <h3 class="text-xl font-bold text-gray-900">Gratis</h3>
          <p class="mt-2 text-sm text-gray-600">Para productores individuales</p>
        </div>

        <div class="mb-6">
          <p class="text-4xl font-extrabold text-gray-900">$0</p>
          <p class="text-sm text-gray-500 mt-1">Para siempre</p>
        </div>

        <ul class="mb-8 space-y-3 flex-1">
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">1 granja</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Animales ilimitados</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Control de reproducción completo</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Recordatorios y áreas</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Respaldo y restauración</span>
          </li>
        </ul>

        <a
          href="https://panel.migranja.app/auth"
          class="block w-full rounded-xl border-2 border-green-600 bg-white px-6 py-3 text-center font-semibold text-green-700 hover:bg-green-50 transition-colors"
        >
          Comenzar Gratis
        </a>
      </div>

      <!-- Plan Pro -->
      <div class="relative flex flex-col rounded-2xl border-2 border-green-600 bg-white p-8 shadow-lg ring-1 ring-green-600/20">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="inline-block rounded-full bg-green-600 px-4 py-1 text-sm font-semibold text-white">
            Recomendado
          </span>
        </div>

        <div class="mb-6">
          <h3 class="text-xl font-bold text-gray-900">Pro</h3>
          <p class="mt-2 text-sm text-gray-600">Para granjas en crecimiento</p>
        </div>

        <div class="mb-6">
          <p class="text-4xl font-extrabold text-gray-900">$250 <span class="text-base font-normal text-gray-500">MXN/mes</span></p>
          <p class="text-sm text-gray-500 mt-1">Por cada granja o colaborador adicional</p>
        </div>

        <ul class="mb-8 space-y-3 flex-1">
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700"><strong>Todo</strong> lo del plan Gratis</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Granjas ilimitadas</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Colaboradores ilimitados</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Soporte prioritario</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm text-gray-700">Facturación gestionada por el equipo</span>
          </li>
        </ul>

        <a
          href="https://panel.migranja.app/auth"
          class="block w-full rounded-xl bg-green-600 px-6 py-3 text-center font-semibold text-white shadow-lg shadow-green-600/25 hover:bg-green-700 transition-colors"
        >
          Comenzar Gratis y Crecer
        </a>
      </div>
    </div>

    <!-- Ejemplo de costos -->
    <div class="mx-auto mt-12 max-w-2xl">
      <div class="rounded-xl bg-gray-50 p-6 text-center">
        <p class="text-sm font-medium text-gray-700 mb-3">Ejemplo de costo mensual</p>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-600">
          <span>3 granjas + 2 colaboradores = <strong class="text-gray-900">$1,000 MXN/mes</strong></span>
        </div>
        <p class="mt-2 text-xs text-gray-500">Plan anual disponible con descuento</p>
      </div>
    </div>
  </div>
</section>
